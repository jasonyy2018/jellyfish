# =========================
# Jellyfish Production Env
# =========================

# --- Core data services ---
DATABASE_URL="postgresql://jellyfish:<strong-db-password>@db:5432/jellyfish"
REDIS_URL="redis://redis:6379"

# --- Security ---
JWT_SECRET="<generate-64-char-random-secret>"
JELLYFISH_ADMIN_TOKEN="<generate-strong-admin-token>"

# --- API rate limiting / maintenance ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
NODE_OFFLINE_THRESHOLD_MINUTES=2

# --- Service URLs ---
JELLYFISH_WEB_URL="https://web.your-domain.com"
JELLYFISH_DASHBOARD_URL="https://dashboard.your-domain.com"
JELLYFISH_API_URL="https://api.your-domain.com"

# --- API keys ---
# Server-side key used by dashboard server calls and agent auth.
JELLYFISH_API_KEY="<provisioned-user-api-key>"
# Public key used by browser client requests to protected node/task endpoints.
NEXT_PUBLIC_JELLYFISH_API_KEY="<same-or-scoped-client-key>"

# --- Browser-side API endpoints ---
NEXT_PUBLIC_JELLYFISH_API_URL="https://api.your-domain.com"
NEXT_PUBLIC_JELLYFISH_API_WS_URL="https://api.your-domain.com"

# --- Agent runtime ---
JELLYFISH_BASE_URL="https://api.your-domain.com"
JELLYFISH_NODE_NAME="prod-node-01"
JELLYFISH_NODE_TYPE="openclaw"
JELLYFISH_SKILLS_DIR="./skills"
JELLYFISH_SKILL_TIMEOUT_MS=120000

# --- Data retention ---
LOG_RETENTION_DAYS=14
METRIC_RETENTION_DAYS=14

# --- Docker DB bootstrapping ---
POSTGRES_USER="jellyfish"
POSTGRES_PASSWORD="<strong-db-password>"
POSTGRES_DB="jellyfish"
