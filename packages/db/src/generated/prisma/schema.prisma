generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  plan      String   @default("free")
  apiKey    String?  @unique
  role      String   @default("user")
  createdAt DateTime @default(now())
  nodes     Node[]
}

model Node {
  id            String    @id @default(uuid())
  userId        String
  name          String
  type          String
  status        String    @default("offline")
  ip            String?
  version       String?
  lastHeartbeat DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  metrics       Metric[]
  logs          Log[]
  tasks         Task[]

  @@index([userId, status])
  @@index([lastHeartbeat])
}

model Task {
  id          String    @id @default(uuid())
  nodeId      String
  type        String
  status      String    @default("pending")
  payload     Json
  result      Json?
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  lockedAt    DateTime?
  startedAt   DateTime?
  timeoutAt   DateTime?
  finishedAt  DateTime?
  lastError   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  node        Node      @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([nodeId, status, createdAt])
  @@index([status, timeoutAt])
}

model Log {
  id        String   @id @default(uuid())
  nodeId    String
  content   String
  level     String   @default("info")
  createdAt DateTime @default(now())
  node      Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([nodeId, createdAt])
  @@index([level, createdAt])
}

model Metric {
  id        String   @id @default(uuid())
  nodeId    String
  cpu       Int
  memory    Int
  disk      Int
  createdAt DateTime @default(now())
  node      Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([nodeId, createdAt])
}

model ReviewRun {
  id        String   @id @default(uuid())
  prompt    String
  expected  String?
  rules     Json?
  status    String   @default("queued")
  score     Int?
  summary   String?
  rawResult Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}
